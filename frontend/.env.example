# Backend server used by the Next.js route handlers.
# Local development default is http://localhost:5000 when this is unset.
BACKEND_API_BASE_URL=https://masterji-backend-ykwp.onrender.com

# Public base URL used by browser-side service calls.
# Leave blank to use the Next.js same-origin API gateway.
NEXT_PUBLIC_API_BASE_URL=https://masterji-backend-ykwp.onrender.com
